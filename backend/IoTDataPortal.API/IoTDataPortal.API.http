@IoTDataPortal.API_HostAddress = http://localhost:5000

# Replace with a real device API key from the portal
@DeviceApiKey = your-device-api-key-here

### Ingest sensor measurements from a device
POST {{IoTDataPortal.API_HostAddress}}/api/measurements/ingest
X-Api-Key: {{DeviceApiKey}}
Content-Type: application/json

{
  "measurements": [
    { "metricType": "temperature", "value": 24.3, "unit": "°C" },
    { "metricType": "humidity",    "value": 58.1, "unit": "%" },
    { "metricType": "pressure",    "value": 1013.2, "unit": "hPa" },
    { "metricType": "battery",     "value": 87.0, "unit": "%" }
  ]
}

###
